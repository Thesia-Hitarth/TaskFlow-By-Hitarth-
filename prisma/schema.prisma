generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  progress      UserProgress[]
  activities    UserActivity[]
  badges        UserBadge[]
  guideViews    GuideView[]
  exerciseAttempts   ExerciseAttempt[]
  projectSubmissions ProjectSubmission[]
  quizResults        QuizResult[]

  // Onboarding tour status
  hasSeenTour      Boolean  @default(false)

  // Streak tracking
  streakDays       Int      @default(0)
  longestStreak    Int      @default(0)
  lastActivityDate String?  // "2026-06-15"
  createdAt        DateTime @default(now())
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum NodeStatus {
  pending
  in_progress @map("in-progress")
  done
  skipped
}

model UserProgress {
  id           String     @id @default(cuid())
  userId       String
  taskflowSlug String
  nodeId       String
  status       NodeStatus
  updatedAt    DateTime   @updatedAt
  createdAt    DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, taskflowSlug, nodeId])
  @@index([userId, taskflowSlug])
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model UserActivity {
  id     String @id @default(cuid())
  userId String
  date   String // "2026-06-15"
  count  Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model Badge {
  id          String      @id
  name        String
  description String
  emoji       String
  userBadges  UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model GuideView {
  id        String   @id @default(cuid())
  userId    String
  guideSlug String
  viewedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, guideSlug])
  @@index([guideSlug])
}

model ExerciseAttempt {
  id           String   @id @default(cuid())
  userId       String
  exerciseId   String
  status       String   @default("attempted") // "attempted" | "solved"
  lastCode     String   @db.Text             // saves their latest attempt so they can resume
  attemptCount Int      @default(1)
  solvedAt     DateTime?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseId])
}

model ProjectSubmission {
  id          String   @id @default(cuid())
  userId      String
  projectId   String
  repoUrl     String?
  liveUrl     String?
  description String?
  upvotes     Int      @default(0)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
}

model QuizResult {
  id                 String   @id @default(cuid())
  userId             String?
  answers            Json
  primaryRoadmapId   String
  secondaryRoadmapId String?
  reasoning          String
  timeCommitment     String
  createdAt          DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
