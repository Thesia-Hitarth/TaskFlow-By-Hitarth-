generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  progress      UserProgress[]
  activities    UserActivity[]
  badges        UserBadge[]
  guideViews    GuideView[]
  exerciseAttempts   ExerciseAttempt[]
  projectSubmissions ProjectSubmission[]
  quizResults        QuizResult[]

  // Profile additions
  username  String?  @unique
  bio       String?

  // Relations for community
  comments         Comment[]
  commentVotes     CommentVote[]
  commentReports   CommentReport[]
  buddyConnections1 StudyBuddyConnection[] @relation("BuddyUser1")
  buddyConnections2 StudyBuddyConnection[] @relation("BuddyUser2")
  buddyMessages    BuddyMessage[]
  showcaseProjects ShowcaseProject[]
  showcaseUpvotes  ShowcaseUpvote[]

  // Onboarding tour status
  hasSeenTour      Boolean  @default(false)

  // Streak tracking
  streakDays       Int      @default(0)
  longestStreak    Int      @default(0)
  lastActivityDate String?  // "2026-06-15"
  createdAt        DateTime @default(now())

  // Extensions for PWA / Mobile / Notification Feed
  publicProfile    Boolean  @default(true)
  notifications    Notification[]
  contentRequests  ContentRequest[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum NodeStatus {
  pending
  in_progress @map("in-progress")
  done
  skipped
}

model UserProgress {
  id           String     @id @default(cuid())
  userId       String
  taskflowSlug String
  nodeId       String
  status       NodeStatus
  updatedAt    DateTime   @updatedAt
  createdAt    DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, taskflowSlug, nodeId])
  @@index([userId, taskflowSlug])
  @@index([createdAt])
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model UserActivity {
  id     String @id @default(cuid())
  userId String
  date   String // "2026-06-15"
  count  Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model Badge {
  id          String      @id
  name        String
  description String
  emoji       String
  userBadges  UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model GuideView {
  id        String   @id @default(cuid())
  userId    String
  guideSlug String
  viewedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, guideSlug])
  @@index([guideSlug])
}

model ExerciseAttempt {
  id           String   @id @default(cuid())
  userId       String
  exerciseId   String
  status       String   @default("attempted") // "attempted" | "solved"
  lastCode     String   @db.Text             // saves their latest attempt so they can resume
  attemptCount Int      @default(1)
  solvedAt     DateTime?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseId])
}

model ProjectSubmission {
  id          String   @id @default(cuid())
  userId      String
  projectId   String
  repoUrl     String?
  liveUrl     String?
  description String?
  upvotes     Int      @default(0)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
}

model QuizResult {
  id                 String   @id @default(cuid())
  userId             String?
  answers            Json
  primaryRoadmapId   String
  secondaryRoadmapId String?
  reasoning          String
  timeCommitment     String
  createdAt          DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AICache {
  id          String   @id @default(cuid())
  cacheKey    String   @unique
  response    String   @db.Text
  hitCount    Int      @default(1)
  createdAt   DateTime @default(now())
  lastHitAt   DateTime @updatedAt

  @@index([cacheKey])
}

model AIRateLimit {
  id        String   @id @default(cuid())
  key       String
  timestamp DateTime @default(now())

  @@index([key, timestamp])
}

model AIUsageLog {
  id           String   @id @default(cuid())
  userId       String?
  feature      String
  inputTokens  Int
  outputTokens Int
  createdAt    DateTime @default(now())

  @@index([feature, createdAt])
}

// ── Comment system ───────────────────────────────────────────────────────────
model Comment {
  id          String   @id @default(cuid())
  body        String   @db.Text
  authorId    String
  nodeTarget  String?
  guideTarget String?
  parentId    String?
  isAccepted  Boolean  @default(false)
  isHidden    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author  User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies Comment[]     @relation("CommentReplies")
  votes   CommentVote[]
  reports CommentReport[]

  @@index([nodeTarget])
  @@index([guideTarget])
  @@index([authorId])
  @@index([parentId])
}

model CommentVote {
  id        String @id @default(cuid())
  commentId String
  userId    String
  value     Int

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
}

model CommentReport {
  id         String   @id @default(cuid())
  commentId  String
  reporterId String
  reason     String
  createdAt  DateTime @default(now())

  comment  Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reporter User    @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([commentId, reporterId])
}

// ── Study Buddies ─────────────────────────────────────────────────────────────
model StudyBuddyConnection {
  id        String   @id @default(cuid())
  userId1   String
  userId2   String
  status    String   // "pending" | "active" | "ended"
  roadmapId String
  createdAt DateTime @default(now())

  user1    User           @relation("BuddyUser1", fields: [userId1], references: [id], onDelete: Cascade)
  user2    User           @relation("BuddyUser2", fields: [userId2], references: [id], onDelete: Cascade)
  messages BuddyMessage[]

  @@unique([userId1, userId2, roadmapId])
  @@index([userId1])
  @@index([userId2])
}

model BuddyMessage {
  id           String   @id @default(cuid())
  connectionId String
  senderId     String
  body         String   @db.Text
  createdAt    DateTime @default(now())

  connection StudyBuddyConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  sender     User                 @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

// ── Community Showcase ────────────────────────────────────────────────────────
model ShowcaseProject {
  id           String   @id @default(cuid())
  title        String
  description  String   @db.Text
  liveUrl      String?
  repoUrl      String?
  thumbnailUrl String?
  authorId     String
  roadmapId    String
  tags         String[]
  isApproved   Boolean  @default(false)
  createdAt    DateTime @default(now())

  author  User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  upvotes ShowcaseUpvote[]

  @@index([roadmapId])
  @@index([authorId])
  @@index([isApproved])
}

model ShowcaseUpvote {
  id        String @id @default(cuid())
  projectId String
  userId    String

  project ShowcaseProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

// ─── Notification Feed ───────────────────────────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "badge_earned" | "streak_milestone" | "new_guide" | "welcome"
  title     String
  message   String
  linkUrl   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ─── Content Requests ────────────────────────────────────────────────────────
model ContentRequest {
  id          String   @id @default(cuid())
  userId      String?
  title       String
  description String?
  type        String   // "roadmap" | "guide" | "exercise" | "feature"
  upvotes     Int      @default(0)
  status      String   @default("open") // "open" | "in_progress" | "done" | "declined"
  createdAt   DateTime @default(now())
  
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  votes       ContentRequestVote[]
}

model ContentRequestVote {
  id        String         @id @default(cuid())
  userId    String
  requestId String
  request   ContentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  @@unique([userId, requestId])
}

